# =============================================================================
# Beleqet Backend — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000/api/v1

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/beleqet_db

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=https://your-ngrok-or-domain/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Cloudflare R2 (preferred when configured; rotate any exposed credentials)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Initial admin account used by prisma/seed.ts
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin

BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_board_password

# --- Social Logins module (Google + LinkedIn OAuth/OIDC) -------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/v1/auth/linkedin/callback

# Generate with: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 32
SESSION_SECRET=
