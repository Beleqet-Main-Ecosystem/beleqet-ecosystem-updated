# =============================================================================
# Beleqet Backend — Environment Variables Template (.env.example)
# Copy this file to .env and replace placeholders with actual secrets/values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Core Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL Database Connection
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://beleqet_user:your_password@127.0.0.1:5433/beleqet_db"

# -----------------------------------------------------------------------------
# Redis Caching & Queue Storage
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# -----------------------------------------------------------------------------
# JWT & Authentication Secrets
# Generate secrets with: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
SESSION_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS

# Social Token Encryption Key (Generate with: openssl rand -hex 32 or base64)
OAUTH_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# -----------------------------------------------------------------------------
# Two-Factor Authentication (TOTP)
# -----------------------------------------------------------------------------
# Generate key with: openssl rand -hex 32 (produces 64 hex chars for AES-256)
TOTP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
TOTP_ISSUER=Beleqet
# Separate key for temp/challenge tokens (Generate with: openssl rand -hex 64)
TOTP_TEMP_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS

# -----------------------------------------------------------------------------
# Social OAuth Credentials
# -----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/v1/auth/linkedin/callback

# -----------------------------------------------------------------------------
# AI Services & LLMs (OpenAI, Smart Bidding, Resume Brain & Ollama)
# -----------------------------------------------------------------------------
# OpenAI Key used for Smart Bidding & general AI fallback
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq / xAI Grok (Used by Resume Brain AI Extractor)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TIMEOUT_MS=20000
# GROQ_MAX_RETRIES=2

# AI Daily Budget Rate-limiting
RESUME_AI_DAILY_REQUEST_BUDGET=50
RESUME_AI_DAILY_TOKEN_BUDGET=100000
RESUME_AI_BUDGET_WINDOW_SECONDS=86400

# Local LLM for Video Interviews
OLLAMA_URL=http://localhost:11434
VIDEO_INTERVIEW_MAX_BYTES=104857600
VIDEO_INTERVIEW_DOWNLOAD_TIMEOUT_MS=120000
# VIDEO_URL_ALLOWED_HOSTS=cdn.example.com,uploads.example.com

# Search & Aggregation Provider
EXA_API_KEY=your_exa_api_key_here
SEARCH_PROVIDER=exa

# -----------------------------------------------------------------------------
# Payment Gateways (Stripe, PayPal & Chapa)
# -----------------------------------------------------------------------------
# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Chapa (Ethiopia Local Sandbox/Prod)
CHAPA_SECRET_KEY=CHASECK_TEST-your_chapa_secret_key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_chapa_public_key
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

# -----------------------------------------------------------------------------
# Storage & CDN Settings (AWS S3, MinIO & Cloudflare R2)
# -----------------------------------------------------------------------------
# S3 / MinIO
AWS_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=minio_user
AWS_SECRET_ACCESS_KEY=minio_password
AWS_REGION=us-east-1

# Cloudflare R2 Storage (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# CDN Delivery Setup
CDN_BASE_URL=
CDN_CACHE_CONTROL=public, max-age=31536000, immutable

# -----------------------------------------------------------------------------
# Email / SMTP Settings
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=doyle.lind@ethereal.email
SMTP_PASS=your_smtp_password
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM="Beleqet <noreply@beleqet.com>"
SMTP_FROM_ADDRESS="Beleqet <noreply@beleqet.com>"
SMTP_FROM="Beleqet <noreply@beleqet.com>"

# -----------------------------------------------------------------------------
# Initial Database Seed Admin Account
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@beleqet.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin

# -----------------------------------------------------------------------------
# Third-Party Messaging & Monitoring
# -----------------------------------------------------------------------------
# Telegram Integration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

# Bull Queue Dashboard Credentials
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_dashboard_password_here