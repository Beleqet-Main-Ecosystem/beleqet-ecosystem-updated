{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,

    /* Rule 4 — TypeScript Strict Mode is mandatory, and `any` is forbidden.
       `strict` turns on every strict family flag (noImplicitAny, strictNullChecks,
       strictFunctionTypes, etc). `noImplicitAny` is listed explicitly as well so
       the intent is unmistakable in review. */
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
