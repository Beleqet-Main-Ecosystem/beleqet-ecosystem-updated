# Optional: overrides the default theme shown to a first-time visitor
# who has no saved preference yet. Must be one of: light | dark | system.
# Falls back to "system" if unset or invalid. See src/theme/ThemeProvider.tsx.
#
# This module has no API keys, passwords, or other secrets to configure —
# it's included here to show config is read from the environment (Rule 3),
# not because a secret is needed.
NEXT_PUBLIC_DEFAULT_THEME=system
