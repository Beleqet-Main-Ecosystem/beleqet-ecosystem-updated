{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "rootDir": "../src",
  "testRegex": ".*integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@common/(.*)$": "<rootDir>/common/$1",
    "^@modules/(.*)$": "<rootDir>/modules/$1",
    "^@prisma-client$": "<rootDir>/prisma/prisma.service"
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
